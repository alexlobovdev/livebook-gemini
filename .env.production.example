APP_NAME=GeminiService
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://gemini.crm.liveboook.ru
GEMINI_DOMAIN=gemini.crm.liveboook.ru
TRAEFIK_ACME_EMAIL=admin@liveboook.ru

LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=gemini
DB_USERNAME=gemini
DB_PASSWORD=change-me

SESSION_DRIVER=file
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_QUEUE=gemini-process
REDIS_QUEUE_RETRY_AFTER=2100

GEMINI_SERVICE_TOKEN=change-me
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_REQUEST_TIMEOUT_SECONDS=600
GEMINI_CONNECT_TIMEOUT_SECONDS=15
GEMINI_REQUEST_RETRIES=2
GEMINI_RETRY_DELAY_MS=500
GEMINI_QUEUE_NAME=gemini-process
GEMINI_JOB_TRIES=3
GEMINI_JOB_TIMEOUT_SECONDS=1800
GEMINI_JOB_BACKOFF_SECONDS=15,60,180
GEMINI_EVENTS_REDIS_CONNECTION=default
GEMINI_EVENTS_STREAM=gemini:events
GEMINI_EVENTS_MAX_LEN=10000
